# ─── 必填 ───
AGENT_URL=http://agentgo:8080         # AgentGo 服务地址
WORKSPACE_PATH=/workspace             # 共享卷路径

# ─── 可选 (有默认值) ───
PORT=8000                             # BFF 监听端口
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── 超时与限制 ───
AGENT_TIMEOUT=120                     # Agent 单次请求超时 (秒)
SSE_HEARTBEAT_INTERVAL=60             # SSE 心跳间隔 (秒)
UPLOAD_MAX_SIZE=10485760              # 上传文件大小上限 (字节, 默认 10MB)

# ─── 注意 ───
# System Prompt 由 AgentGo 内置管理 (internal/agent/SystemPrompt.md)。
# BFF 不构建、不注入 System Prompt。
